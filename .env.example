# ============================================================================
# Blackbrowed Labs website — environment variables (template)
# ============================================================================
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# `.env.example` is committed as documentation of which variables are expected.
#
# See docs/TECH_STACK.md §10 for full documentation of each secret.

# GitHub fine-grained PAT for the releases loader.
# Scope: Contents: Read-only, Metadata: Read-only on all repos under
# blackbrowed-labs. See §10.1.
PRODUCT_REPOS_PAT=github_pat_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Cloudflare API token for Worker deployments.
# Scope: Workers Scripts Edit + Workers Routes Edit + DNS Edit on the
# blackbrowedlabs.com zone only. See §10.2.
# (Not required yet — will be populated when the Cloudflare token is created.)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Cloudflare Web Analytics token. Public (PUBLIC_*) — embedded into the
# beacon at build time on production deploys only. Source: Cloudflare
# dashboard → Web Analytics → blackbrowedlabs.com → Snippet. Wired into
# .github/workflows/deploy-production.yml as the build step's env.
# BaseLayout gates the beacon on both isProduction() and a non-empty
# token, so leaving this empty in .env / staging means no beacon emits.
PUBLIC_CWA_TOKEN=
