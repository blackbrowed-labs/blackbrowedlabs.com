---
/**
 * Two-button DE / EN language switcher with slash separator.
 * Renders the inactive side as a link to the counterpart URL; if the
 * counterpart is missing, that side is rendered aria-disabled instead
 * of pointing to a 404.
 */

import { getLocaleFromPath, getCounterpartUrl } from '../lib/i18n';
import { getUiStrings } from '../i18n';

const path = Astro.url.pathname;
const currentLocale = getLocaleFromPath(path);
const counterpart = getCounterpartUrl(path);

const strings = getUiStrings(currentLocale).languageSwitcher;

const deActive = currentLocale === 'de';
const enActive = currentLocale === 'en';

// Active side links to the current path (no-op); inactive side links
// to the counterpart when available, otherwise nothing.
const deHref = deActive ? path : counterpart;
const enHref = enActive ? path : counterpart;
---

<div class="lang-switcher" role="group" aria-label={strings.label}>
  {deHref ? (
    <a
      class="lang-switcher__button"
      href={deHref}
      hreflang="de"
      lang="de"
      aria-pressed={deActive ? 'true' : 'false'}
      aria-current={deActive ? 'page' : undefined}
    >{strings.de}</a>
  ) : (
    <span class="lang-switcher__button lang-switcher__button--disabled" aria-disabled="true">
      {strings.de}
    </span>
  )}
  <span class="lang-switcher__divider" aria-hidden="true">/</span>
  {enHref ? (
    <a
      class="lang-switcher__button"
      href={enHref}
      hreflang="en"
      lang="en"
      aria-pressed={enActive ? 'true' : 'false'}
      aria-current={enActive ? 'page' : undefined}
    >{strings.en}</a>
  ) : (
    <span class="lang-switcher__button lang-switcher__button--disabled" aria-disabled="true">
      {strings.en}
    </span>
  )}
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: var(--text-caption);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-caption);
  }

  .lang-switcher__button {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-muted);
    padding: 0.5rem 0.375rem;
    min-height: 44px;
    border-bottom: 1px solid transparent;
    text-decoration: none;
    transition:
      color var(--duration-bbl-fast) var(--ease-bbl),
      border-color var(--duration-bbl-fast) var(--ease-bbl);
  }

  .lang-switcher__button:hover {
    color: var(--color-link-hover);
    border-bottom-color: transparent;
  }

  .lang-switcher__button[aria-pressed="true"],
  .lang-switcher__button[aria-current="page"] {
    color: var(--color-heading);
  }

  .lang-switcher__button--disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .lang-switcher__button:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
    border-radius: var(--radius-bbl-1);
  }

  .lang-switcher__divider {
    color: var(--color-border);
  }
</style>
