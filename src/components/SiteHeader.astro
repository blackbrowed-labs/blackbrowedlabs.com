---
/**
 * Site header — logo left, nav center, language + theme controls right.
 * On mobile (<768px) the nav + controls collapse behind a hamburger.
 *
 * Pass 1 nav scope: About only. Home is reached via the logo link.
 * Pass 2 adds Products / Contact / Impressum / Datenschutz in the same
 * commits that introduce those pages.
 */

import BrandLogo from './BrandLogo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import { getLocaleFromPath } from '../lib/i18n';
import { getUiStrings } from '../i18n';

const path = Astro.url.pathname;
const locale = getLocaleFromPath(path);
const t = getUiStrings(locale);

const homeHref = locale === 'de' ? '/' : '/en';
const aboutHref = locale === 'de' ? '/ueber' : '/en/about';
const aboutActive = path === aboutHref || path === aboutHref + '/';
const contactHref = locale === 'de' ? '/kontakt' : '/en/contact';
const contactActive = path === contactHref || path === contactHref + '/';
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__home" href={homeHref} aria-label={t.logo.ariaLabel}>
      <BrandLogo variant="horizontal" />
    </a>

    <button
      type="button"
      class="site-header__menu-trigger"
      aria-label={t.nav.ariaLabel}
      aria-controls="primary-nav"
      aria-expanded="false"
      data-menu-trigger
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <nav class="site-header__nav" id="primary-nav" aria-label={t.nav.ariaLabel}>
      <ul class="site-header__list">
        <li>
          <a
            class="site-header__link"
            href={aboutHref}
            aria-current={aboutActive ? 'page' : undefined}
          >{t.nav.about}</a>
        </li>
        <li>
          <a
            class="site-header__link"
            href={contactHref}
            aria-current={contactActive ? 'page' : undefined}
          >{t.nav.contact}</a>
        </li>
      </ul>
      <div class="site-header__controls">
        <LanguageSwitcher />
        <ThemeToggle />
      </div>
    </nav>
  </div>
</header>

<script>
  (function () {
    const trigger = document.querySelector('[data-menu-trigger]');
    const nav = document.getElementById('primary-nav');
    if (!(trigger instanceof HTMLElement) || !(nav instanceof HTMLElement)) return;
    // Re-bind to typed locals so the L67 instanceof narrowing propagates into
    // every inner-function closure below. Type-only; same DOM references.
    const triggerEl: HTMLElement = trigger;
    const navEl: HTMLElement = nav;

    // Mirrors the mobile breakpoint used by the CSS: hamburger + nav panel
    // live below 768px; desktop nav is always visible.
    const mobileMql = window.matchMedia('(max-width: 767px)');

    function isOpen() {
      return triggerEl.getAttribute('aria-expanded') === 'true';
    }

    // Focusable elements currently VISIBLE inside the nav panel. Used for
    // initial focus placement on open and for the Tab focus-trap cycle.
    // offsetWidth/Height is 0 for display:none subtrees (e.g. the closed
    // theme-toggle options), so those are filtered out automatically.
    function getFocusables() {
      const selector = 'a[href], button:not(:disabled), [tabindex]:not([tabindex="-1"])';
      return Array.from(navEl.querySelectorAll<HTMLElement>(selector))
        .filter(function (el) { return el.offsetWidth > 0 || el.offsetHeight > 0; });
    }

    function open() {
      triggerEl.setAttribute('aria-expanded', 'true');
      navEl.dataset.open = 'true';
      document.body.classList.add('menu-open');
      // Move focus into the panel for keyboard + screen-reader continuity.
      const first = getFocusables()[0];
      if (first) first.focus({ preventScroll: true });
    }

    // restoreFocus=true returns focus to the hamburger (Escape / tap-outside);
    // =false leaves focus alone (hamburger click — trigger already focused;
    // desktop-resize — hamburger is hidden at ≥768px anyway).
    function close(restoreFocus: boolean) {
      triggerEl.setAttribute('aria-expanded', 'false');
      delete navEl.dataset.open;
      document.body.classList.remove('menu-open');
      if (restoreFocus) triggerEl.focus({ preventScroll: true });
    }

    triggerEl.addEventListener('click', function () {
      if (isOpen()) close(false);
      else open();
    });

    // Tap outside the panel (and outside the trigger) closes the menu.
    document.addEventListener('click', function (e) {
      if (!isOpen()) return;
      const t = e.target;
      if (!(t instanceof Element)) return;
      if (navEl.contains(t) || triggerEl.contains(t)) return;
      close(true);
    });

    // Escape closes + restores focus. Tab / Shift+Tab cycles within the panel.
    document.addEventListener('keydown', function (e) {
      if (!isOpen()) return;

      if (e.key === 'Escape') {
        close(true);
        return;
      }

      if (e.key !== 'Tab') return;

      const focusables = getFocusables();
      if (focusables.length === 0) return;
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      const active = document.activeElement;

      if (e.shiftKey) {
        if (active === first || !navEl.contains(active)) {
          e.preventDefault();
          last.focus({ preventScroll: true });
        }
      } else {
        if (active === last) {
          e.preventDefault();
          first.focus({ preventScroll: true });
        }
      }
    });

    // If the viewport crosses to ≥768px while the menu is open, close cleanly:
    // desktop nav is always visible and must not leave body-scroll locked or
    // the hamburger's aria-expanded state mismatched with the visible nav.
    mobileMql.addEventListener('change', function (e) {
      if (!e.matches && isOpen()) close(false);
    });
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .site-header__inner {
    max-width: var(--max-width-site);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-header__home {
    color: inherit;
    text-decoration: none;
    border-bottom: none;
    display: inline-flex;
    align-items: center;
  }
  .site-header__home:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 4px;
    border-radius: var(--radius-bbl-1);
  }

  .site-header__menu-trigger {
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-bbl-2);
    color: var(--color-text);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .site-header__menu-trigger:hover { border-color: var(--color-border); }
  .site-header__menu-trigger:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
  }
  .site-header__menu-trigger svg { width: 24px; height: 24px; }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .site-header__list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.5rem;
  }

  .site-header__link {
    color: var(--color-text);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    padding: 0.5rem 0;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    border-bottom: 1px solid transparent;
    transition:
      color var(--duration-bbl-fast) var(--ease-bbl),
      border-color var(--duration-bbl-fast) var(--ease-bbl);
  }
  .site-header__link:hover { color: var(--color-link-hover); }
  .site-header__link[aria-current="page"] {
    color: var(--color-heading);
    border-bottom-color: var(--color-heading);
  }
  .site-header__link:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
    border-radius: var(--radius-bbl-1);
  }

  .site-header__controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Mobile: hamburger + collapsible panel */
  @media (max-width: 767px) {
    .site-header__nav {
      position: absolute;
      top: 100%;
      right: 0;
      left: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      flex-direction: column;
      align-items: stretch;
      padding: 1rem 1.25rem 1.5rem;
      gap: 1rem;
      display: none;
      z-index: 10;
    }
    .site-header__nav[data-open] { display: flex; }
    .site-header__list {
      flex-direction: column;
      gap: 0.5rem;
    }
    .site-header__controls {
      justify-content: space-between;
      border-top: 1px solid var(--color-border);
      padding-top: 1rem;
    }
  }

  @media (min-width: 768px) {
    .site-header__menu-trigger { display: none; }
  }
</style>
