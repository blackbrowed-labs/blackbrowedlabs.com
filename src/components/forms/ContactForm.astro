---
/**
 * Contact form component (Phase B.1).
 *
 * Renders the visible form submitted to the Cloudflare Worker at
 * POST /api/contact. The Worker handles honeypot drop, Workers Rate
 * Limit, Turnstile siteverify, validation, and send_email; on
 * completion it 303-redirects back to this page with `?ok=1` or
 * `?error=<code>`. A small inline script reads the URL query at page
 * load and renders the appropriate status message in an aria-live
 * region.
 *
 * Locale is passed as a prop. The hidden `_returnTo` field carries
 * the locale-specific path so the Worker knows where to redirect
 * (validated against an allowlist on the Worker side; see
 * src/worker/contact.ts).
 *
 * Turnstile site key is embedded directly per env via
 * PUBLIC_ENVIRONMENT. The values mirror
 * `wrangler.jsonc env.<env>.vars.TURNSTILE_SITE_KEY` because Astro
 * builds at build time and cannot read wrangler runtime vars; both
 * sources stay manually in sync. Site keys are public; the matching
 * TURNSTILE_SECRET_KEY lives only as a Worker secret (set via
 * `wrangler secret put`) and never enters the repo or page HTML.
 */

import type { Locale } from '../../i18n';
import { getUiStrings } from '../../i18n';

interface Props {
  locale: Locale;
  returnTo: string;
}

const { locale, returnTo } = Astro.props;
const t = getUiStrings(locale).contactForm;

const TURNSTILE_SITE_KEYS = {
  production: '0x4AAAAAADE4-1cr4L0pjUTs',
  staging: '0x4AAAAAADE4z9pthsMBK_n7',
} as const;

const turnstileSiteKey =
  import.meta.env.PUBLIC_ENVIRONMENT === 'production'
    ? TURNSTILE_SITE_KEYS.production
    : TURNSTILE_SITE_KEYS.staging;
---

<form
  class="contact-form"
  action="/api/contact"
  method="POST"
  aria-label={t.ariaLabel}
>
  <output
    id="contact-status"
    class="contact-form__status"
    role="status"
    aria-live="polite"
    aria-label={t.errors.regionAriaLabel}
    data-success={t.success}
    data-error-validation={t.errors.validation}
    data-error-turnstile={t.errors.turnstile}
    data-error-rate-limit={t.errors.rate_limit}
    data-error-server={t.errors.server}
    data-error-generic={t.errors.generic}
  ></output>

  <div class="contact-form__field">
    <label for="contact-name">{t.fields.nameLabel}</label>
    <input
      id="contact-name"
      name="name"
      type="text"
      required
      aria-required="true"
      autocomplete="name"
    />
  </div>

  <div class="contact-form__field">
    <label for="contact-email">{t.fields.emailLabel}</label>
    <input
      id="contact-email"
      name="email"
      type="email"
      required
      aria-required="true"
      autocomplete="email"
    />
  </div>

  <div class="contact-form__field">
    <label for="contact-message">{t.fields.messageLabel}</label>
    <textarea
      id="contact-message"
      name="message"
      rows="6"
      required
      aria-required="true"
    ></textarea>
  </div>

  {/*
    Honeypot: visually hidden, AT-hidden, but present in the DOM so
    naive scrapers fill it. Off-screen positioning rather than
    display:none — bots routinely skip display:none fields.
  */}
  <div class="contact-form__honeypot" aria-hidden="true">
    <label for="contact-website">{t.fields.honeypotLabel}</label>
    <input
      id="contact-website"
      name="website"
      type="text"
      tabindex="-1"
      autocomplete="off"
    />
  </div>

  <div class="contact-form__turnstile">
    <div
      class="cf-turnstile"
      data-sitekey={turnstileSiteKey}
      data-theme="auto"
    ></div>
    <p class="contact-form__turnstile-attribution">{t.turnstile.attribution}</p>
  </div>

  <input type="hidden" name="_returnTo" value={returnTo} />

  <button type="submit" class="contact-form__submit">{t.submit.label}</button>
</form>

{/*
  Turnstile loader — auto-renders any `.cf-turnstile` element on the
  page after async load. Marked `is:inline` so Astro emits the script
  tag verbatim without bundling. No-JS visitors skip this entirely
  and submit without a token; the Worker degrades gracefully
  (honeypot + rate-limit cover that path).
*/}
<script async src="https://challenges.cloudflare.com/turnstile/v0/api.js" is:inline></script>

{/*
  Status renderer + draft preservation + per-field error indicator.

  - Reads `?ok` / `?error` from the URL on page load; fills the
    aria-live region with the matching i18n string.
  - On `?error=*`, restores the user's form values from sessionStorage
    (cleared on `?ok=1` or fresh visit) and marks individual invalid
    fields with `.contact-form__field--error` so the user sees WHICH
    field the Worker rejected, not just a generic "something failed".
  - On submit, saves the draft to sessionStorage so a server-side
    redirect can restore it. Honeypot, Turnstile token, and _returnTo
    are intentionally NOT preserved.
  - Live error-class management: the `invalid` event marks a field on
    blocked submit; `input` events clear the class when the field
    becomes valid again.

  The local `isLikelyEmail` mirrors the Worker's regex so we can flag
  Safari-accepted-but-Worker-rejected emails (Safari's built-in
  type=email validator is lenient about TLD presence).
*/}
<script is:inline>
  (function () {
    const STORAGE_KEY = 'bbl-contact-form-draft';
    const FIELDS = ['name', 'email', 'message'];
    const EMAIL_RE = /^\S+@\S+\.\S+$/;

    const status = document.getElementById('contact-status');
    const form = document.querySelector('.contact-form');
    if (!status || !form) return;

    const params = new URLSearchParams(location.search);
    const okFlag = params.get('ok') === '1';
    const errorCode = params.get('error');

    function isFieldInvalid(input) {
      if (!input.checkValidity()) return true;
      // Worker-mirroring email check (Safari's type=email is lenient).
      if (input.name === 'email' && input.value && !EMAIL_RE.test(input.value)) {
        return true;
      }
      return false;
    }

    function setFieldError(input, isError) {
      const wrapper = input.closest('.contact-form__field');
      if (!wrapper) return;
      if (isError) wrapper.classList.add('contact-form__field--error');
      else wrapper.classList.remove('contact-form__field--error');
    }

    // Restore preserved draft on any error redirect; clear it on success.
    if (errorCode) {
      try {
        const raw = sessionStorage.getItem(STORAGE_KEY);
        if (raw) {
          const draft = JSON.parse(raw);
          FIELDS.forEach(function (name) {
            const input = form.querySelector('[name="' + name + '"]');
            if (input && typeof draft[name] === 'string') {
              input.value = draft[name];
            }
          });
        }
      } catch (_) { /* ignore restore errors */ }

      // After restore, mark whichever fields the Worker plausibly
      // rejected so the user sees which one to fix.
      FIELDS.forEach(function (name) {
        const input = form.querySelector('[name="' + name + '"]');
        if (input) setFieldError(input, isFieldInvalid(input));
      });
    } else if (okFlag) {
      try { sessionStorage.removeItem(STORAGE_KEY); } catch (_) {}
    }

    // Render status message from URL params.
    if (okFlag) {
      status.textContent = status.dataset.success || '';
      status.classList.add('contact-form__status--ok');
    } else if (errorCode) {
      const map = {
        validation: status.dataset.errorValidation,
        turnstile: status.dataset.errorTurnstile,
        rate_limit: status.dataset.errorRateLimit,
        server: status.dataset.errorServer,
      };
      status.textContent = map[errorCode] || status.dataset.errorGeneric || '';
      status.classList.add('contact-form__status--error');
    }

    // Live error-class management: mark on blocked-submit `invalid`
    // event; clear as the user corrects the field.
    FIELDS.forEach(function (name) {
      const input = form.querySelector('[name="' + name + '"]');
      if (!input) return;
      input.addEventListener('invalid', function () {
        setFieldError(input, true);
      });
      input.addEventListener('input', function () {
        if (!isFieldInvalid(input)) setFieldError(input, false);
      });
    });

    // Save draft on submit so a server-side error redirect can restore it.
    form.addEventListener('submit', function () {
      const draft = {};
      FIELDS.forEach(function (name) {
        const input = form.querySelector('[name="' + name + '"]');
        if (input) draft[name] = input.value;
      });
      try {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify(draft));
      } catch (_) { /* ignore quota errors */ }
    });
  })();
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 32rem;
  }

  .contact-form__status:empty { display: none; }
  .contact-form__status--ok {
    background: var(--color-surface-card);
    border-left: 2px solid var(--bbl-primary);
    padding: 1rem 1.25rem;
    color: var(--color-text);
    font-size: var(--text-small);
    line-height: 1.5;
  }
  .contact-form__status--error {
    background: var(--color-error-bg);
    border-left: 2px solid var(--bbl-error);
    padding: 1rem 1.25rem;
    color: var(--color-error-text);
    font-size: var(--text-small);
    line-height: 1.5;
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .contact-form__field label {
    color: var(--color-text);
    font-weight: var(--font-weight-medium);
    font-size: var(--text-small);
  }
  .contact-form__field input,
  .contact-form__field textarea {
    font: inherit;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-bbl-2);
    padding: 0.625rem 0.75rem;
    font-size: var(--text-body);
    line-height: 1.4;
  }
  .contact-form__field input:focus-visible,
  .contact-form__field textarea:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 1px;
    border-color: var(--color-focus-ring);
  }
  .contact-form__field textarea {
    resize: vertical;
    min-height: 8rem;
  }

  /*
    Field-level error state. Two triggers — `:user-invalid` (modern
    pseudo-class that only fires AFTER the user has interacted, so
    untouched required fields don't go red on first paint) and the
    explicit `.contact-form__field--error` class set by the inline
    script on server-error returns. Both produce the same red border
    and red label.
  */
  .contact-form__field input:user-invalid,
  .contact-form__field textarea:user-invalid,
  .contact-form__field--error input,
  .contact-form__field--error textarea {
    border-color: var(--bbl-error);
  }
  .contact-form__field--error label {
    color: var(--color-error-text);
  }

  /*
    Honeypot: invisible to humans + AT, present in DOM for scrapers.
    position:absolute + off-screen — NOT display:none, which some
    bots check to skip. tabindex=-1 keeps keyboard nav clean.
  */
  .contact-form__honeypot {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .contact-form__turnstile {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .contact-form__turnstile-attribution {
    color: var(--color-text-muted);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-caption);
    margin: 0;
  }

  .contact-form__submit {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    min-height: 44px;
    padding: 0.625rem 1.125rem;
    font-size: var(--text-body);
    font-weight: var(--font-weight-medium);
    line-height: 1.2;
    border: 1px solid transparent;
    border-radius: var(--radius-bbl-2);
    background: var(--color-cta-bg);
    color: var(--color-cta-text);
    cursor: pointer;
    transition: background var(--duration-bbl-fast) var(--ease-bbl);
  }
  .contact-form__submit:hover { background: var(--bbl-primary-hover); }
  .contact-form__submit:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
  }
</style>
