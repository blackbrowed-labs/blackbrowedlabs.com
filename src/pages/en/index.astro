---
/**
 * Homepage (EN — secondary).
 * Matches design/handoff-bundle/design/pages/02-homepage-en.html.
 * Copy migrates from inline literals to the `editorial` collection
 * in Pass 2 / A.4. The H2 + lead-paragraph body lives in the
 * Markdown file; the lead paragraph is authored as inline HTML to
 * preserve the global `.lead` utility class binding.
 *
 * The "What's being built →" secondary link is omitted in Pass 1
 * (no /en/products route yet). Phase C.3 restores it in the commit
 * that adds the Products page.
 */

import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandLogo from '../../components/BrandLogo.astro';

const entry = await getEntry('editorial', 'home.en');
if (!entry) throw new Error('Missing editorial entry: home.en');
const { Content } = await render(entry);
const { title, tagline, heroLead, description } = entry.data;
// Schema fields are collection-wide optional but home.en must populate them.
if (!title || !tagline || !heroLead || !description) {
  throw new Error('home.en editorial entry missing required fields');
}
---

<BaseLayout title={title} description={description}>
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__arc" aria-hidden="true">
        <BrandLogo variant="mark" />
      </div>
      <h1 class="display">{tagline}</h1>
      <p class="lead">{heroLead}</p>
    </div>
  </section>

  <section class="secondary">
    <div class="secondary__inner">
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--color-border);
    min-height: calc(100vh - 6rem);
  }

  .hero__inner {
    width: 100%;
    max-width: var(--max-width-site);
    margin: 0 auto;
    padding: 6rem 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero__arc {
    --brand-arc-height: 6.875rem;
    margin-bottom: 6rem;
    line-height: 0;
  }

  .hero .display {
    color: var(--color-heading);
    margin: 0 auto 4rem;
    font-weight: var(--font-weight-light);
    max-width: 16ch;
    text-align: center;
  }

  .hero .lead {
    color: var(--color-text);
    max-width: 54ch;
    margin: 0 auto;
    text-align: center;
  }

  .secondary {
    background: var(--color-surface-warm);
    border-bottom: 1px solid var(--color-border);
  }

  .secondary__inner {
    max-width: var(--max-width-site);
    margin: 0 auto;
    padding: 8rem 3rem;
  }

  .secondary h2 {
    max-width: 20ch;
    margin: 0 0 2rem;
  }

  .secondary .lead {
    max-width: 70ch;
    margin: 0;
  }

  @media (max-width: 767px) {
    .hero__inner {
      padding: 3.5rem 1.5rem 4rem;
    }
    .hero__arc {
      --brand-arc-height: 3.5rem;
      margin-bottom: 2.5rem;
    }
    .hero .display {
      font-size: 2.75rem;
      line-height: 1.08;
      letter-spacing: -0.02em;
      margin-bottom: 2rem;
      max-width: 12ch;
    }
    .hero .lead {
      font-size: 1.0625rem;
      max-width: 32ch;
    }

    .secondary__inner {
      padding: 3.5rem 1.5rem;
    }
    .secondary h2 {
      font-size: 1.75rem;
      letter-spacing: -0.01em;
      max-width: 14ch;
      margin-bottom: 1.25rem;
    }
    .secondary .lead {
      font-size: 1.0625rem;
      max-width: none;
    }
  }
</style>
